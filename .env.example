# LLM backend to use: "llama" (local llama-cpp server) or "claude" (Anthropic API)
LLM_BACKEND=llama

# OpenAI-compatible llama-cpp-python server URL
LLAMA_SERVER_URL=http://localhost:8000/v1

# Anthropic API key (only required when LLM_BACKEND=claude)
ANTHROPIC_API_KEY=

# Path to MSFragger JAR file
MSFRAGGER_PATH=

# Path to Comet executable
COMET_PATH=

# Path to Trans-Proteomic Pipeline bin directory (contains PeptideProphet, ASAPRatio, ProteinProphet)
TPP_BIN_PATH=

# Path to Percolator executable
PERCOLATOR_PATH=

# Base output directory for all run artifacts
OUTPUT_DIR=./output

# Default autonomy mode for orchestrator: full | balanced | supervised
DEFAULT_AUTONOMY_MODE=balanced

# Default protein database FASTA path
DATABASE_PATH=

# Path to local GGUF model file for llama_cpp.server --model
MODEL_PATH=

# Set to true to skip the LLM entirely and run pipeline stages directly
NO_LLM_MODE=false
