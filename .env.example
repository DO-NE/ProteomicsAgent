# LLM backend to use: "llama" (local llama-cpp server) or "claude" (Anthropic API) or "openai" (OpenAI compatible API)
LLM_BACKEND=llama

# OpenAI-compatible llama-cpp-python server URL
LLAMA_SERVER_URL=http://localhost:8000/v1

# OpenAI API base URL (only required when LLM_BACKEND=openai)
OPENAI_API_URL=https://api.openai.com/v1

# OpenAI API key (only required when LLM_BACKEND=openai)
OPENAI_API_KEY=

# For OpenAI-compatible APIs, the model ID to use for agent (e.g. "gpt-4-0613" or "gpt-3.5-turbo-0613")
OPENAI_MODEL_ID=

# Antropic API base URL (only required when LLM_BACKEND=claude), this also allow use of other Anthropic-compatible APIs or proxies
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Anthropic API key (only required when LLM_BACKEND=claude)
ANTHROPIC_API_KEY=

# For Anthropic API, the model ID to use for agent (e.g. "claude-2" or "claude-sonnet-4-6")
ANTROPIC_MODEL_ID=claude-sonnet-4-6

# Path to MSFragger JAR file
MSFRAGGER_PATH=

# Path to Comet executable
COMET_PATH=

# Path to Trans-Proteomic Pipeline bin directory (contains PeptideProphet, ASAPRatio, ProteinProphet)
TPP_BIN_PATH=

# Path to Percolator executable
PERCOLATOR_PATH=

# Base output directory for all run artifacts
OUTPUT_DIR=./output

# Default autonomy mode for orchestrator: full | balanced | supervised
DEFAULT_AUTONOMY_MODE=balanced

# Default protein database FASTA path
DATABASE_PATH=

# Path to local GGUF model file for llama_cpp.server --model
MODEL_PATH=

# Set to true to skip the LLM entirely and run pipeline stages directly
NO_LLM_MODE=false
